<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OOP_Practice.UI"
		x:Class="OOP_Practice.UI.MainWindow"
        x:DataType="local:WindowViewModel"
        Title="OOP LAB 2"
        Width="{Binding WindowWidth}" Height="{Binding WindowHeight}">

    <Grid ColumnDefinitions="250, *">
        
        <ScrollViewer Grid.Column="0" Background="#2D2D30">
            
            <StackPanel Spacing="10" Margin="15">
                <TextBlock Text="СПИСОК ФІГУР" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,15,0,5"/>
                <ListBox x:Name="ShapesList" Height="150" SelectionChanged="ShapesList_SelectionChanged" Margin="0,0,0,15"/>
                <Button Content="Застосувати зміни до вибраної" Click="UpdateShape_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#BAB58A" Margin="0,0,0,15"/>
                
                <TextBlock Text="ПАРАМЕТРИ ФІГУРИ" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto" Margin="0,0,0,15">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Позиція X:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <NumericUpDown x:Name="NumX" Grid.Row="0" Grid.Column="1" Value="0" Minimum="0" Maximum="2000" Margin="0,0,0,5" Height="20"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Позиція Y:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <NumericUpDown x:Name="NumY" Grid.Row="1" Grid.Column="1" Value="0" Minimum="0" Maximum="2000" Margin="0,0,0,5" Height="20"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Позиція Z:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <NumericUpDown x:Name="NumZ" Grid.Row="2" Grid.Column="1" Value="0" Minimum="0" Maximum="2000" Margin="0,0,0,5" Height="20"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ширина:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <NumericUpDown x:Name="NumW" Grid.Row="3" Grid.Column="1" Value="10" Minimum="1" Maximum="500" Margin="0,0,0,5" Height="20"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Висота:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <NumericUpDown x:Name="NumH" Grid.Row="4" Grid.Column="1" Value="10" Minimum="1" Maximum="500" Margin="0,0,0,5" Height="20"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Глибина:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <NumericUpDown x:Name="NumD" Grid.Row="5" Grid.Column="1" Value="10" Minimum="1" Maximum="500" Margin="0,0,0,0" Height="20"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Радіус (R):" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <NumericUpDown x:Name="NumOuterR" Grid.Row="6" Grid.Column="1" Value="10" Minimum="1" Maximum="500" Margin="0,0,0,5" Height="20"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Внутр (r):" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <NumericUpDown x:Name="NumInnerR" Grid.Row="7" Grid.Column="1" Value="10" Minimum="1" Maximum="500" Margin="0,0,0,5" Height="20"/>
                </Grid>

                <TextBlock Text="ДОДАТИ ФІГУРУ" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <Button Content="Додати Коло" Click="AddCircle_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Додати Кільце" Click="AddRing_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Додати Кільце (Заф.)" Click="AddFilledRing_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Додати Сферу" Click="AddSphere_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Додати Циліндр" Click="AddCylinder_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Додати Тор" Click="AddTorus_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                
                <TextBlock Text="КЕРУВАННЯ" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,15,0,5"/>
                <Grid RowDefinitions="Auto, Auto, Auto, Auto" ColumnDefinitions="Auto, *" Margin="0,0,0,5">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Дельта (t):" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <NumericUpDown x:Name="NumT" Grid.Row="0" Grid.Column="1" Value="1" Minimum="1" Maximum="500" Height="20"/>
                </Grid>

                <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *, *" Margin="0,0,0,10">
                    <Button Grid.Row="0" Grid.Column="1" Content="↑" Click="MoveUp_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2"/>
                    <Button Grid.Row="1" Grid.Column="0" Content="←" Click="MoveLeft_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="→" Click="MoveRight_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="↓" Click="MoveDown_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2"/>
                </Grid>

                <Grid ColumnDefinitions="Auto, Auto" Margin="0,0,0,10">
                    <Button Grid.Column="0" Content="Масштабувати (*)" Click="ScaleCanvas_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#4B0082" Margin="0,0,5,0"/>
                    <NumericUpDown x:Name="NumS" Grid.Column="1" Value="1.0" Minimum="0.1" Maximum="10" Increment="0.1" FormatString="0.0" Height="20"/>
                </Grid>
                
                <TextBlock Text="ФАЙЛИ" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,15,0,5"/>
                <Button Content="Зберегти (JSON)" Click="Save_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#2E8B57"/>
                <Button Content="Завантажити" Click="Load_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#4682B4"/>
                <Button Content="Об'єднати" Click="Merge_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#4646B4"/>
                
                <Button Content="Очистити полотно" Click="ClearCanvas_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#8B0000" Margin="0,20,0,0"/>
                <Button Content="Очистити кеш (смертельно)" Click="ClearCache_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#8B0000" Margin="0,5,0,0"/>
                
            </StackPanel>
            
        </ScrollViewer>

        <local:ShapeCanvas Name="Canvas" Grid.Column="1" ClipToBounds="True" />
        
    </Grid>
    
</Window>